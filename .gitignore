# ============================================================
# .gitignore — YouTube Downloader API
# ============================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables — NEVER commit these!
.env
.env.local
.env.development
.env.production
.env.staging
.env.test

# Logs
logs/
*.log
npm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage / test output
coverage/
.nyc_output/
test-results/

# Build / compiled output
dist/
build/
out/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE and editor files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# Optional caches
.eslintcache
.cache/
.parcel-cache/
.turbo/

# Temporary files
tmp/
temp/
